      <div class="input-area">
        <input id="q-input" type="text" placeholder="Ask anything about CS1101…" />
        <button id="send-btn" onclick="sendQuestion()">
          <svg viewBox="0 0 24 24"><path d="M2 21L23 12 2 3v7l15 2-15 2z"/></svg>
