const msgs = document.getElementById('chat-messages');
const input = document.getElementById('q-input');

function addMsg(html, isUser, showSource) {
  const wrap = document.createElement('div');
  wrap.className = 'msg' + (isUser ? ' user' : '');

  const av = document.createElement('div');
  av.className = 'msg-av ' + (isUser ? 'user-av' : 'bot-av');
  av.textContent = isUser ? 'ME' : '🤖';

  const col = document.createElement('div');
  col.className = 'msg-col';

  const bubble = document.createElement('div');
  bubble.className = 'bubble ' + (isUser ? 'user-bubble' : 'bot-bubble');
  bubble.innerHTML = html;
  col.appendChild(bubble);

  if (!isUser && showSource !== false) {
    const ref = document.createElement('span');
    ref.className = 'source-ref';
    ref.textContent = '📄 CS1101 Syllabus · WPU';
    col.appendChild(ref);
  }

  wrap.appendChild(av);
  wrap.appendChild(col);
  msgs.appendChild(wrap);
  msgs.scrollTop = msgs.scrollHeight;
  return wrap;
}

function addTyping() {
  const wrap = document.createElement('div');
  wrap.className = 'msg';
  wrap.id = 'typing-indicator';
  wrap.innerHTML = `<div class="msg-av bot-av">🤖</div><div class="msg-col"><div class="bubble bot-bubble"><div class="typing-wrap"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div></div>`;
  msgs.appendChild(wrap);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-indicator');
  if (t) t.remove();
}

function askChip(btn) {
  input.value = btn.textContent;
  sendQuestion();
}

async function sendQuestion() {
  const q = input.value.trim();
  if (!q) return;
  input.value = '';
  input.disabled = true;

  addMsg(q, true, false);
  addTyping();

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are CS1101 Study Buddy, a friendly and upbeat AI assistant for students in CS1101 "AI for Everyone" at William Paterson University, taught by Prof. Nan Wang.

Answer ONLY based on the syllabus content below. Be warm, encouraging, and use occasional emoji. Keep answers concise and clear — use bullet points when listing multiple things. If a question is not covered in the syllabus, kindly say so and suggest the student email Prof. Wang at wangn1@wpunj.edu or check Blackboard. Never invent information.

SYLLABUS:
${SYLLABUS}`,
        messages: [{ role: 'user', content: q }]
      })
    });

    const data = await res.json();
    removeTyping();
    const answer = data.content?.[0]?.text || "Hmm, I couldn't get an answer right now. Please try again!";
    addMsg(answer.replace(/\n\n/g, '<br><br>').replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>'));
  } catch (e) {
    removeTyping();
    addMsg("Oops! Something went wrong. Please try again in a moment. 😅", false, false);
  } finally {
    input.disabled = false;
    input.focus();
  }
}

input.addEventListener('keydown', e => { if (e.key === 'Enter') sendQuestion(); });
</script>
