<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CS1101 Study Buddy · AI for Everyone</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --grape: #6C2BD9;
    --grape-light: #8B5CF6;
    --sky: #0EA5E9;
    --mint: #10B981;
    --tangerine: #F97316;
    --rose: #F43F5E;
    --ink: #0F0A1E;
    --ink-soft: #2D2546;
    --mist: #F5F3FF;
    --card-bg: #FFFFFF;
    --radius: 20px;
    --font-display: 'Baloo 2', cursive;
    --font-body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--ink);
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── ANIMATED BACKGROUND ─── */
  .bg-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, #0F0A1E 0%, #1a0533 40%, #0a1628 70%, #0F0A1E 100%);
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: drift 12s ease-in-out infinite alternate;
  }
  .orb1 { width: 500px; height: 500px; background: #6C2BD9; top: -150px; left: -100px; animation-duration: 14s; }
  .orb2 { width: 400px; height: 400px; background: #0EA5E9; top: 40%; right: -120px; animation-duration: 10s; animation-delay: -4s; }
  .orb3 { width: 350px; height: 350px; background: #10B981; bottom: -100px; left: 30%; animation-duration: 16s; animation-delay: -8s; }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(40px, 30px) scale(1.1); }
  }

  /* ─── LAYOUT ─── */
  .page {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100vh;
  }

  /* ─── HEADER ─── */
  header {
    padding: 0 clamp(16px, 5vw, 60px);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    background: rgba(15,10,30,0.5);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--grape), var(--sky));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: #fff;
  }

  .logo-text span { color: var(--grape-light); }

  nav { display: flex; gap: 8px; align-items: center; }

  .nav-pill {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
    padding: 6px 14px;
    border-radius: 30px;
    text-decoration: none;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .nav-pill:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.07);
  }

  .nav-cta {
    background: linear-gradient(135deg, var(--grape), var(--sky));
    color: #fff !important;
    border-color: transparent !important;
    font-weight: 600;
  }

  .nav-cta:hover { opacity: 0.9; transform: translateY(-1px); }

  /* ─── MAIN ─── */
  main {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 0;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    padding: clamp(32px, 5vw, 60px) clamp(16px, 5vw, 60px);
    align-items: start;
  }

  /* ─── LEFT HERO ─── */
  .hero {
    padding-right: 60px;
    padding-top: 20px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(108, 43, 217, 0.2);
    border: 1px solid rgba(139, 92, 246, 0.4);
    border-radius: 30px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    color: #C4B5FD;
    margin-bottom: 28px;
    animation: fadeUp 0.6s ease both;
  }

  .badge-dot {
    width: 7px; height: 7px;
    background: var(--mint);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.08;
    color: #fff;
    margin-bottom: 22px;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  h1 .gradient-word {
    background: linear-gradient(90deg, var(--grape-light), var(--sky), var(--mint));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    max-width: 440px;
    margin-bottom: 36px;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  /* ─── INFO CARDS ─── */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 40px;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .info-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 16px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    transition: all 0.2s;
  }

  .info-card:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.18);
    transform: translateY(-2px);
  }

  .info-icon {
    font-size: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-label {
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 3px;
  }

  .info-value {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.88);
    line-height: 1.4;
  }

  /* ─── TOPIC PILLS ─── */
  .topics-section {
    animation: fadeUp 0.6s 0.4s ease both;
  }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .topic-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topic-pill {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 13px;
    border-radius: 20px;
    border: 1px solid;
    transition: all 0.2s;
    cursor: default;
  }

  .tp-purple { background: rgba(108,43,217,0.15); border-color: rgba(139,92,246,0.35); color: #C4B5FD; }
  .tp-blue { background: rgba(14,165,233,0.12); border-color: rgba(14,165,233,0.3); color: #7DD3FC; }
  .tp-green { background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.3); color: #6EE7B7; }
  .tp-orange { background: rgba(249,115,22,0.12); border-color: rgba(249,115,22,0.3); color: #FED7AA; }
  .tp-rose { background: rgba(244,63,94,0.12); border-color: rgba(244,63,94,0.3); color: #FDA4AF; }

  .topic-pill:hover { transform: translateY(-2px); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── CHAT PANEL ─── */
  .chat-panel {
    background: rgba(255,255,255,0.97);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.15);
    display: flex;
    flex-direction: column;
    height: 680px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);
    animation: fadeUp 0.6s 0.15s ease both;
    position: sticky;
    top: 90px;
  }

  .chat-top {
    background: linear-gradient(135deg, #6C2BD9, #0EA5E9);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .bot-avatar-wrap {
    position: relative;
  }

  .bot-avatar {
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
  }

  .online-dot {
    position: absolute;
    bottom: 1px; right: 1px;
    width: 11px; height: 11px;
    background: #10B981;
    border-radius: 50%;
    border: 2px solid #6C2BD9;
  }

  .chat-top-info h3 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: #fff;
  }

  .chat-top-info p {
    font-size: 11px;
    color: rgba(255,255,255,0.75);
  }

  .chat-top-badge {
    margin-left: auto;
    background: rgba(255,255,255,0.18);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.8px;
    padding: 4px 10px;
    border-radius: 20px;
  }

  /* ─── MESSAGES ─── */
  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: #F8F6FF;
    scrollbar-width: thin;
    scrollbar-color: rgba(108,43,217,0.2) transparent;
  }

  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-thumb { background: rgba(108,43,217,0.25); border-radius: 4px; }

  .msg { display: flex; gap: 9px; align-items: flex-end; }
  .msg.user { flex-direction: row-reverse; }

  .msg-av {
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0;
  }

  .bot-av { background: linear-gradient(135deg, #6C2BD9, #0EA5E9); }
  .user-av {
    background: linear-gradient(135deg, #F97316, #F43F5E);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    font-family: var(--font-display);
  }

  .msg-col { display: flex; flex-direction: column; gap: 4px; max-width: 82%; }
  .msg.user .msg-col { align-items: flex-end; }

  .bubble {
    padding: 10px 14px;
    border-radius: 18px;
    font-size: 13.5px;
    line-height: 1.6;
    color: #1a1030;
  }

  .bot-bubble {
    background: #fff;
    border: 1px solid rgba(108,43,217,0.12);
    border-bottom-left-radius: 5px;
    box-shadow: 0 1px 4px rgba(108,43,217,0.07);
  }

  .user-bubble {
    background: linear-gradient(135deg, #6C2BD9, #0EA5E9);
    color: #fff;
    border-bottom-right-radius: 5px;
  }

  .source-ref {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 600;
    color: #8B5CF6;
    background: #EDE9FE;
    padding: 3px 9px;
    border-radius: 10px;
  }

  /* ─── TYPING ─── */
  .typing-wrap { display: flex; align-items: center; gap: 5px; padding: 10px 14px; }
  .typing-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #8B5CF6;
    animation: tdot 1.3s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.15s; }
  .typing-dot:nth-child(3) { animation-delay: 0.3s; }
  @keyframes tdot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* ─── CHIPS ─── */
  .chips-area {
    padding: 10px 14px;
    border-top: 1px solid rgba(108,43,217,0.1);
    background: #fff;
    flex-shrink: 0;
  }

  .chips-label {
    font-size: 10px;
    font-weight: 600;
    color: rgba(0,0,0,0.35);
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 8px;
  }

  .chips-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .chip {
    font-family: var(--font-body);
    font-size: 11.5px;
    font-weight: 500;
    padding: 5px 11px;
    border-radius: 20px;
    border: 1.5px solid;
    cursor: pointer;
    background: transparent;
    transition: all 0.18s;
    line-height: 1;
  }

  .c1 { border-color: #6C2BD9; color: #6C2BD9; }
  .c2 { border-color: #0EA5E9; color: #0EA5E9; }
  .c3 { border-color: #10B981; color: #10B981; }
  .c4 { border-color: #F97316; color: #F97316; }
  .c5 { border-color: #F43F5E; color: #F43F5E; }
  .c6 { border-color: #6C2BD9; color: #6C2BD9; }

  .chip:hover { transform: translateY(-2px); box-shadow: 0 3px 10px rgba(0,0,0,0.12); }
  .chip:active { transform: scale(0.96); }

  /* ─── INPUT ─── */
  .input-area {
    display: flex;
    gap: 8px;
    padding: 12px 14px;
    background: #fff;
    border-top: 1px solid rgba(108,43,217,0.08);
    flex-shrink: 0;
  }

  #q-input {
    flex: 1;
    padding: 10px 16px;
    border: 1.5px solid rgba(108,43,217,0.2);
    border-radius: 30px;
    font-size: 13.5px;
    font-family: var(--font-body);
    outline: none;
    color: #1a1030;
    background: #FAF8FF;
    transition: border-color 0.2s;
  }

  #q-input:focus { border-color: #6C2BD9; background: #fff; }
  #q-input::placeholder { color: rgba(0,0,0,0.35); }

  #send-btn {
    width: 40px; height: 40px;
    border: none;
    border-radius: 50%;
    background: linear-gradient(135deg, #6C2BD9, #0EA5E9);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 0.15s;
    box-shadow: 0 4px 14px rgba(108,43,217,0.35);
  }

  #send-btn:hover { transform: scale(1.06); box-shadow: 0 6px 18px rgba(108,43,217,0.45); }
  #send-btn:active { transform: scale(0.94); }
  #send-btn svg { width: 16px; height: 16px; fill: #fff; }

  /* ─── FOOTER ─── */
  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 24px;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  footer a { color: rgba(255,255,255,0.45); text-decoration: none; }
  footer a:hover { color: rgba(255,255,255,0.7); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    main {
      grid-template-columns: 1fr;
      padding: 24px 16px;
    }
    .hero { padding-right: 0; margin-bottom: 32px; }
    .chat-panel { position: static; height: 600px; }
    nav .nav-pill:not(.nav-cta) { display: none; }
  }

  @media (max-width: 480px) {
    .info-grid { grid-template-columns: 1fr; }
    h1 { font-size: 32px; }
  }
</style>
</head>
<body>

<div class="bg-canvas">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
</div>

<div class="page">

  <header>
    <a href="#" class="logo">
      <div class="logo-icon">🤖</div>
      <span class="logo-text">CS<span>1101</span> Buddy</span>
    </a>
    <nav>
      <a href="#" class="nav-pill">Syllabus Info</a>
      <a href="mailto:wangn1@wpunj.edu" class="nav-pill">Email Prof. Wang</a>
